# BroSolution / Operational Grosir environment template
# Copy to .env for local development. Keep .env untracked and replace every change_me_* placeholder before production.

# Postgres (local compose + runtime connection strings)
POSTGRES_DB=operational
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_APP_USER=app
POSTGRES_APP_PASSWORD=change_me_app_password
POSTGRES_ADMIN_USER=app_admin
POSTGRES_ADMIN_PASSWORD=change_me_admin_password
DATABASE_URL=postgres://app:change_me_app_password@db:5432/operational
DATABASE_ADMIN_URL=postgres://app_admin:change_me_admin_password@db:5432/operational

# Redis / queues / exports
REDIS_URL=redis://redis:6379
BULLMQ_QUEUE_PREFIX=brosolution
EXPORT_DIR=/data/exports

# API / web
API_PORT=4000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Production reverse proxy (P8)
DOMAIN=brosolution.example.com
ACME_EMAIL=ops@example.com

# Current auth runtime names
JWT_ACCESS_SECRET=change_me_48_byte_base64_access_signing_key
JWT_REFRESH_SECRET=change_me_48_byte_base64_refresh_signing_key
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600

# P3 auth hardening: HTTP-only cookie/session semantics (no localStorage tokens)
MFA_KMS_KEY=change_me_32_byte_base64_mfa_kms_key
SESSION_COOKIE_NAME=brosolution_session
SESSION_COOKIE_DOMAIN=
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_NAME=brosolution_csrf
CSRF_HEADER_NAME=x-csrf-token
# Development/test only. API startup refuses this variable in production-like environments.
AUTH_MFA_BYPASS_EMAILS=
MFA_CHALLENGE_RATE_LIMIT_POINTS=5
MFA_CHALLENGE_RATE_LIMIT_SECONDS=60
MFA_CHALLENGE_MAX_FAILURES=5

# SMTP / transactional email
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=BroSolution <no-reply@localhost>

# Billing PSPs (planned P5)
# Runtime must try BILLING_ACTIVE_PSP first and fall back to the other configured PSP when active PSP config is incomplete.
BILLING_ENABLED=false
BILLING_ACTIVE_PSP=midtrans
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=change_me_midtrans_server_key
MIDTRANS_CLIENT_KEY=change_me_midtrans_client_key
MIDTRANS_MERCHANT_ID=change_me_midtrans_merchant_id
XENDIT_ENV=sandbox
XENDIT_SECRET_KEY=change_me_xendit_secret_key
XENDIT_PUBLIC_KEY=change_me_xendit_public_key
XENDIT_WEBHOOK_TOKEN=change_me_xendit_webhook_token

# Observability (P1)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=
LOG_LEVEL=info
PROMETHEUS_METRICS_ENABLED=true
LOKI_URL=http://loki:3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password
GRAFANA_BIND=127.0.0.1:3001
PROMETHEUS_BIND=127.0.0.1:9090
LOKI_BIND=127.0.0.1:3100
PROMETHEUS_RETENTION=30d

# Backup target (planned P8)
BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
BACKUP_S3_BUCKET=brosolution-backups
BACKUP_S3_REGION=ap-southeast-1
BACKUP_S3_ACCESS_KEY=change_me_backup_access_key
BACKUP_S3_SECRET_KEY=change_me_backup_secret_key
BACKUP_S3_PREFIX=prod/
BACKUP_RETENTION_DAYS=30

# E2E / Playwright helpers
E2E_ADMIN_EMAIL=admin@local
E2E_ADMIN_PASSWORD=replace-me-admin-password
E2E_BASE_URL=http://localhost:3000
E2E_GROSIR_OWNER_PASSWORD=replace-me-owner-password
E2E_GROSIR_SLUG=demo
PLAYWRIGHT_BASE_URL=http://localhost:3000
