# Postgres
POSTGRES_DB=operational
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_APP_USER=app
POSTGRES_APP_PASSWORD=change_me_app_password
POSTGRES_ADMIN_USER=app_admin
POSTGRES_ADMIN_PASSWORD=change_me_admin_password
DATABASE_URL=postgres://app:***@db:5432/operational
DATABASE_ADMIN_URL=postgres://app_admin:***@db:5432/operational

# Redis / queues
REDIS_URL=redis://redis:6379
BULLMQ_QUEUE_PREFIX=operational

# Auth / tokens (current code)
JWT_ACCESS_SECRET=replace-me-min-32-chars
JWT_REFRESH_SECRET=replace-me-min-32-chars
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
INVITE_TOKEN_TTL_SECONDS=604800
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# Auth hardening (planned P3)
MFA_KMS_KEY=replace-me-32-byte-base64
SESSION_COOKIE_NAME=brosolution_session
SESSION_COOKIE_DOMAIN=localhost
SESSION_COOKIE_SECURE=false

# SMTP / MailHog
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=operational-app-dev
MAIL_FROM=operational-app-dev
MAILHOG_WEB_PORT=8025

# App
NODE_ENV=development
API_PORT=4000
WEB_PORT=3000
PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
EXPORT_DIR=/data/exports
# Comma-separated origins allowed by the API CORS middleware. Must include the
# Next.js public URL (WEB_PORT) so the browser may call the API cross-origin.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Billing / PSP (planned P5)
BILLING_ENABLED=false
# Admin-selected default PSP. Runtime billing must fall back to the other configured PSP
# when this provider is selected but its required env/config is incomplete.
BILLING_ACTIVE_PSP=midtrans
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=replace-me-midtrans-server-key
MIDTRANS_CLIENT_KEY=replace-me-midtrans-client-key
MIDTRANS_MERCHANT_ID=replace-me-midtrans-merchant-id
XENDIT_ENV=sandbox
XENDIT_SECRET_KEY=replace-me-xendit-secret-key
XENDIT_PUBLIC_KEY=replace-me-xendit-public-key
XENDIT_WEBHOOK_TOKEN=replace-me-xendit-webhook-token

# Observability (planned P1)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info

# Backups (planned P8)
BACKUP_S3_ENDPOINT=replace-me-s3-endpoint
BACKUP_S3_BUCKET=replace-me-s3-bucket
BACKUP_S3_ACCESS_KEY=replace-me-s3-access-key
BACKUP_S3_SECRET_KEY=replace-me-s3-secret-key

# E2E / local test defaults (optional)
E2E_ADMIN_EMAIL=admin@example.test
E2E_ADMIN_PASSWORD=replace-me-admin-password
E2E_BASE_URL=http://localhost:3000
E2E_GROSIR_OWNER_PASSWORD=replace-me-owner-password
E2E_GROSIR_SLUG=demo
PLAYWRIGHT_BASE_URL=http://localhost:3000
