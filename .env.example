# Postgres
POSTGRES_DB=operational
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_app_password
POSTGRES_ADMIN_USER=app_admin
POSTGRES_ADMIN_PASSWORD=change_me_admin_password
DATABASE_URL=postgres://app:change_me_app_password@db:5432/operational
DATABASE_ADMIN_URL=postgres://app_admin:change_me_admin_password@db:5432/operational

# Redis
REDIS_URL=redis://redis:6379

# Auth / tokens
JWT_SECRET=change_me_dev_jwt_secret_at_least_32_chars
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
INVITE_TOKEN_TTL_SECONDS=604800
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# SMTP / MailHog
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=operational-app-dev
MAILHOG_WEB_PORT=8025

# App
API_PORT=4000
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
EXPORT_DIR=/data/exports
