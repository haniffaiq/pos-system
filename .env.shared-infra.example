# BroSolution / POS — shared-infra deployment template.
# Copy to .env on the host and replace every change_me_* placeholder.
# Used with docker-compose.shared-infra.yml. Do not commit .env.
#
#   docker compose -f docker-compose.shared-infra.yml --env-file .env up -d --build
#
# Postgres / Redis / MinIO are owned by the `infa-basic` stack and reached
# over the external `shared-infra` Docker network via the postgres / redis /
# minio aliases. TLS is terminated by the host nginx reverse proxy.

# Shared Docker network (owned by infa-basic).
SHARED_NETWORK=shared-infra

# Loopback host ports published for the nginx reverse proxy.
WEB_HOST_PORT=3200
API_HOST_PORT=4200

# Database — shared Postgres 16 (infa-basic), app-scoped role.
DATABASE_URL=postgresql://change_me_user:change_me_password@postgres:5432/change_me_db

# Redis — shared Redis 7 (infa-basic). The app ACL user is locked to the
# `<APP_NAMESPACE>:*` keyspace; keys/queues are prefixed via APP_NAMESPACE.
REDIS_URL=redis://change_me_user:change_me_password@redis:6379/0
APP_NAMESPACE=change_me_namespace
EXPORT_DIR=/data/exports

# Auth / tokens
JWT_ACCESS_SECRET=change_me_48_byte_base64_access_signing_key
JWT_REFRESH_SECRET=change_me_48_byte_base64_refresh_signing_key
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
INVITE_TOKEN_TTL_SECONDS=604800
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
MFA_KMS_KEY=change_me_32_byte_base64_mfa_kms_key
SESSION_COOKIE_NAME=postyb_session
SESSION_COOKIE_DOMAIN=pos.thankyoubro.id
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_NAME=postyb_csrf
CSRF_HEADER_NAME=x-csrf-token
RATE_LIMIT_DISABLED=false

# Public hosts (TLS terminated by host nginx)
DOMAIN=pos.thankyoubro.id
ACME_EMAIL=hanif@jakitlabs.com
PUBLIC_APP_URL=https://pos.thankyoubro.id
NEXT_PUBLIC_API_URL=
CORS_ORIGINS=https://pos.thankyoubro.id

# SMTP / transactional email — fill with real provider credentials.
SMTP_HOST=change_me_smtp_host
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=change_me_smtp_user
SMTP_PASSWORD=change_me_smtp_password
SMTP_FROM=POS ThankYouBro <no-reply@pos.thankyoubro.id>
MAIL_FROM=POS ThankYouBro <no-reply@pos.thankyoubro.id>

# Billing PSPs — set keys per provider before enabling.
BILLING_ENABLED=false
BILLING_ACTIVE_PSP=midtrans
MIDTRANS_ENV=production
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
XENDIT_ENV=production
XENDIT_SECRET_KEY=
XENDIT_PUBLIC_KEY=
XENDIT_WEBHOOK_TOKEN=

# MinIO — shared object storage (infa-basic), app-scoped key.
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key
MINIO_BUCKET=change_me_bucket
BACKUP_RETENTION_DAYS=30

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
LOG_LEVEL=info
PROMETHEUS_METRICS_ENABLED=true
