{
  "name": "operational-web-app",
  "private": true,
  "scripts": {
    "dev": "docker compose --profile dev up --build",
    "migrate": "tsx db/migrate.ts",
    "seed:admin": "tsx db/seeds/seed-admin.ts",
    "test": "pnpm -r --filter './apps/*' --filter './packages/*' test",
    "test:redis": "REDIS_URL=${REDIS_URL:-redis://localhost:6379} pnpm --filter @app/api test -- --run src/lib/refreshStore.test.ts src/queue/queues.test.ts",
    "test:e2e": "pnpm --filter @app/e2e test"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0",
  "dependencies": {
    "argon2": "^0.41.0",
    "pg": "^8.13.0"
  }
}
