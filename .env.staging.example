# BroSolution staging environment template
# Copy to .env.staging on the staging host and replace every change_me_* placeholder.
# Do not commit .env.staging. Run with:
# docker compose --env-file .env.staging -f docker-compose.prod.yml -f docker-compose.staging.yml --profile prod up -d --build

# Public staging host terminated by Caddy. STAGING_* values override DOMAIN/ACME_EMAIL in the staging overlay.
STAGING_DOMAIN=staging.brosolution.id
STAGING_ACME_EMAIL=ops@example.com
DOMAIN=staging.brosolution.id
ACME_EMAIL=ops@example.com
COMPOSE_PROFILES=prod

# Postgres (staging compose + runtime connection strings)
POSTGRES_DB=operational_staging
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_staging_postgres_password
POSTGRES_APP_USER=app
POSTGRES_APP_PASSWORD=change_me_staging_app_password
POSTGRES_ADMIN_USER=app_admin
POSTGRES_ADMIN_PASSWORD=change_me_staging_admin_password
DATABASE_URL=postgres://app:change_me_staging_app_password@db:5432/operational_staging
DATABASE_ADMIN_URL=postgres://app_admin:change_me_staging_admin_password@db:5432/operational_staging

# Redis / queues / exports
REDIS_URL=redis://redis:6379
BULLMQ_QUEUE_PREFIX=staging
EXPORT_DIR=/data/exports

# API/web URLs
PUBLIC_APP_URL=https://staging.brosolution.id
NEXT_PUBLIC_API_URL=
CORS_ORIGINS=https://staging.brosolution.id

# Auth runtime names
JWT_ACCESS_SECRET=change_me_48_byte_base64_access_signing_key
JWT_REFRESH_SECRET=change_me_48_byte_base64_refresh_signing_key
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600
MFA_KMS_KEY=change_me_32_byte_base64_mfa_kms_key
SESSION_COOKIE_NAME=brosolution_staging_session
SESSION_COOKIE_DOMAIN=staging.brosolution.id
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_NAME=brosolution_staging_csrf
CSRF_HEADER_NAME=x-csrf-token
MFA_CHALLENGE_RATE_LIMIT_POINTS=5
MFA_CHALLENGE_RATE_LIMIT_SECONDS=60
MFA_CHALLENGE_MAX_FAILURES=5

# SMTP / transactional email
SMTP_HOST=change_me_smtp_host
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=change_me_smtp_user
SMTP_PASSWORD=change_me_smtp_password
SMTP_FROM=BroSolution Staging <no-reply@staging.brosolution.id>

# Billing PSPs: staging uses sandbox PSPs by default.
# Runtime must try BILLING_ACTIVE_PSP first and fall back to the other configured PSP when active PSP config is incomplete.
BILLING_ENABLED=true
BILLING_ACTIVE_PSP=midtrans
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=change_me_midtrans_sandbox_server_key
MIDTRANS_CLIENT_KEY=change_me_midtrans_sandbox_client_key
MIDTRANS_MERCHANT_ID=change_me_midtrans_sandbox_merchant_id
XENDIT_ENV=sandbox
XENDIT_SECRET_KEY=change_me_xendit_sandbox_secret_key
XENDIT_PUBLIC_KEY=change_me_xendit_sandbox_public_key
XENDIT_WEBHOOK_TOKEN=change_me_xendit_sandbox_webhook_token

# Observability (staging)
SENTRY_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=staging
NEXT_PUBLIC_SENTRY_RELEASE=
LOG_LEVEL=info
PROMETHEUS_METRICS_ENABLED=true
LOKI_URL=http://loki:3100
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_staging_grafana_password
GRAFANA_BIND=127.0.0.1:3001
PROMETHEUS_BIND=127.0.0.1:9090
LOKI_BIND=127.0.0.1:3100
PROMETHEUS_RETENTION=30d

# Backup target (staging prefix; use separate least-privilege credentials from production)
BACKUP_S3_ENDPOINT=https://s3.amazonaws.com
BACKUP_S3_BUCKET=brosolution-staging-backups
BACKUP_S3_REGION=ap-southeast-1
BACKUP_S3_ACCESS_KEY=change_me_staging_backup_access_key
BACKUP_S3_SECRET_KEY=change_me_staging_backup_secret_key
BACKUP_S3_PREFIX=staging/
BACKUP_RETENTION_DAYS=14

# E2E / Playwright helpers against staging
E2E_ADMIN_EMAIL=admin@staging.local
E2E_ADMIN_PASSWORD=replace-me-staging-admin-password
E2E_BASE_URL=https://staging.brosolution.id
E2E_GROSIR_OWNER_PASSWORD=replace-me-staging-owner-password
E2E_GROSIR_SLUG=demo
PLAYWRIGHT_BASE_URL=https://staging.brosolution.id
